# App
NEXT_PUBLIC_APP_NAME=Lapangin
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth
# Production requires a long random value. Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-at-least-32-characters

# Demo auth credentials for local/mock mode only
DEMO_ADMIN_EMAIL=admin@lapangin.id
DEMO_ADMIN_PASSWORD=change-this-demo-admin-password
DEMO_OWNER_EMAIL=owner@lapangin.id
DEMO_OWNER_PASSWORD=change-this-demo-owner-password

# Database adapter: mock | google_sheets | postgres
# Use mock for local demo. Use postgres only after PostgresAdapter is implemented.
DATABASE_PROVIDER=mock

# Google Sheets demo adapter
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=

# PostgreSQL / Supabase later
DATABASE_URL=
POSTGRES_URL=

# Notification later
EMAIL_FROM=
RESEND_API_KEY=
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=

# WhatsApp (wwebjs)
# URL of the wwebjs service (e.g. http://localhost:3001)
WWEBJS_API_URL=
# API key for authenticating with the wwebjs service
WWEBJS_API_KEY=
