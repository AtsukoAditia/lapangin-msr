# ============================================
# Lapangin — Environment Variables
# Copy to .env.local and fill in your values
# ============================================

# --- App ---
NEXT_PUBLIC_APP_NAME=Lapangin
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Auth ---
# Generate with: openssl rand -base64 48
JWT_SECRET=

# --- Database ---
# Adapter: mock | postgres
DATABASE_PROVIDER=mock
DATABASE_URL=postgresql://user:password@localhost:5432/lapangin
POSTGRES_URL=postgresql://user:password@localhost:5432/lapangin

# --- Google Sheets (optional, for demo adapter) ---
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=

# --- WhatsApp (wwebjs) ---
# See https://wwebjs.dev — run your own wwebjs service
WWEBJS_API_URL=http://localhost:3001
WWEBJS_API_KEY=

# --- Email (Resend) ---
EMAIL_FROM=noreply@lapangin.id
RESEND_API_KEY=

# --- Web Push (VAPID) ---
# Generate with: npx web-push generate-vapid-keys
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
